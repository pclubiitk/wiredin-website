---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

interface Heading {
    depth: number;
    slug: string;
    text: string;
}

type Props = CollectionEntry<"blog">["data"] & {
    headings?: Heading[];
};

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    tags,
    authors,
    enableToc,
    headings = [],
} = Astro.props;
const tocHeadings = headings.filter((h: Heading) => h.depth <= 3);
const showToc = enableToc && tocHeadings.length > 0;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
    </head>

    <body>
        <Header />

        <!-- Reading progress bar -->
        <div class="progress-bar" id="progress-bar"></div>

        <div class={showToc ? "layout-with-toc" : "layout-simple"}>
            {
                showToc && (
                    <aside class="toc-sidebar" id="toc-sidebar">
                        <nav class="toc">
                            <p class="toc-label">on this page</p>
                            <ul>
                                {tocHeadings.map((h) => (
                                    <li class={`depth-${h.depth}`}>
                                        <a href={`#${h.slug}`}>{h.text}</a>
                                    </li>
                                ))}
                            </ul>
                        </nav>
                    </aside>
                )
            }

            <main>
                <article>
                    <header class="post-header">
                        <p class="meta">
                            <FormattedDate date={pubDate} />
                            {
                                updatedDate && (
                                    <span class="updated">
                                        {" "}
                                        · updated{" "}
                                        <FormattedDate date={updatedDate} />
                                    </span>
                                )
                            }
                            {
                                authors && authors.length > 0 && (
                                    <span class="authors">
                                        {" "}
                                        · by {authors.join(", ")}
                                    </span>
                                )
                            }
                        </p>
                        <h1>{title}</h1>
                        {
                            tags && tags.length > 0 && (
                                <div class="tags">
                                    {tags.map((tag) => (
                                        <a href={`/tags/${tag}`} class="tag">
                                            #{tag}
                                        </a>
                                    ))}
                                </div>
                            )
                        }
                    </header>

                    {
                        heroImage && (
                            <div class="hero-img">
                                <Image
                                    width={1020}
                                    height={510}
                                    src={heroImage}
                                    alt=""
                                />
                            </div>
                        )
                    }

                    <div class="content">
                        <slot />
                    </div>
                </article>
            </main>
        </div>

        <!-- Back to top -->
        <button class="back-to-top" id="back-to-top" aria-label="Back to top">↑</button>

        {showToc && (
            <Fragment>
                <!-- Mobile TOC FAB -->
                <button class="toc-fab" id="toc-fab" aria-label="Table of contents" aria-expanded="false">
                    <span class="toc-fab-icon">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="1" y="3" width="6" height="1.5" rx="0.75" fill="currentColor"/>
                            <rect x="1" y="7" width="9" height="1.5" rx="0.75" fill="currentColor"/>
                            <rect x="1" y="11" width="7" height="1.5" rx="0.75" fill="currentColor"/>
                            <rect x="9" y="3" width="6" height="1.5" rx="0.75" fill="currentColor" opacity="0.4"/>
                            <rect x="12" y="7" width="3" height="1.5" rx="0.75" fill="currentColor" opacity="0.4"/>
                            <rect x="10" y="11" width="5" height="1.5" rx="0.75" fill="currentColor" opacity="0.4"/>
                        </svg>
                    </span>
                    <span class="toc-fab-label">Contents</span>
                </button>

                <!-- Backdrop -->
                <div class="toc-backdrop" id="toc-backdrop"></div>

                <!-- Drawer -->
                <div class="toc-drawer" id="toc-drawer" role="dialog" aria-label="Table of contents" aria-modal="true">
                    <div class="toc-drawer-header">
                        <p class="toc-label">on this page</p>
                        <button class="toc-close" id="toc-close" aria-label="Close table of contents">✕</button>
                    </div>
                    <nav class="toc toc-mobile">
                        <ul>
                            {tocHeadings.map((h) => (
                                <li class={`depth-${h.depth}`}>
                                    <a href={`#${h.slug}`}>{h.text}</a>
                                </li>
                            ))}
                        </ul>
                    </nav>
                </div>
            </Fragment>
        )}

        <Footer />

        <script>
            const bar = document.getElementById("progress-bar");
            function updateProgress() {
                const scrollTop = window.scrollY;
                const docHeight = document.documentElement.scrollHeight - window.innerHeight;
                const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
                if (bar) bar.style.width = pct + "%";
            }

            const btn = document.getElementById("back-to-top");
            function updateBackToTop() {
                btn?.classList.toggle("visible", window.scrollY > 400);
            }
            btn?.addEventListener("click", () =>
                window.scrollTo({ top: 0, behavior: "smooth" })
            );

            const desktopLinks = document.querySelectorAll(".toc-sidebar .toc a");
            const mobileLinks  = document.querySelectorAll(".toc-mobile a");

            const headingEls = Array.from(desktopLinks.length ? desktopLinks : mobileLinks)
                .map((link) => {
                    const id = link.getAttribute("href")?.slice(1);
                    return id ? document.getElementById(id) : null;
                })
                .filter(Boolean) as HTMLElement[];

            function updateToc() {
                let current = 0;
                for (let i = 0; i < headingEls.length; i++) {
                    if (headingEls[i].getBoundingClientRect().top <= 100) current = i;
                }
                desktopLinks.forEach((l, i) => l.classList.toggle("active", i === current));
                mobileLinks.forEach((l, i)  => l.classList.toggle("active", i === current));
            }

            window.addEventListener("scroll", () => {
                updateProgress();
                updateBackToTop();
                if (headingEls.length) updateToc();
            }, { passive: true });

            updateProgress();
            updateBackToTop();
            if (headingEls.length) updateToc();

            const fab      = document.getElementById("toc-fab");
            const drawer   = document.getElementById("toc-drawer");
            const backdrop = document.getElementById("toc-backdrop");
            const closeBtn = document.getElementById("toc-close");

            function openDrawer() {
                drawer?.classList.add("open");
                backdrop?.classList.add("open");
                fab?.setAttribute("aria-expanded", "true");
                document.body.style.overflow = "hidden";
                (drawer?.querySelector("a") as HTMLElement)?.focus();
            }

            function closeDrawer() {
                drawer?.classList.remove("open");
                backdrop?.classList.remove("open");
                fab?.setAttribute("aria-expanded", "false");
                document.body.style.overflow = "";
                fab?.focus();
            }

            fab?.addEventListener("click", openDrawer);
            closeBtn?.addEventListener("click", closeDrawer);
            backdrop?.addEventListener("click", closeDrawer);
            mobileLinks.forEach((link) => link.addEventListener("click", closeDrawer));
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape" && drawer?.classList.contains("open")) closeDrawer();
            });
        </script>
    </body>
</html>

<style>
    .progress-bar {
        position: fixed;
        top: 48px;
        left: 0;
        height: 2px;
        width: 0;
        background: var(--accent);
        z-index: 200;
        transition: width 0.05s linear;
        pointer-events: none;
    }

    .back-to-top {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 36px;
        height: 36px;
        background: var(--bg-raised);
        border: 1px solid var(--border);
        color: var(--fg-muted);
        font-size: 16px;
        border-radius: var(--radius);
        cursor: pointer;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s, color 0.15s, border-color 0.15s, transform 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font);
        z-index: 150;
    }
    .back-to-top.visible {
        opacity: 1;
        pointer-events: auto;
    }
    .back-to-top:hover {
        color: var(--accent);
        border-color: var(--accent);
        transform: translateY(-2px);
    }
    .back-to-top:active {
        transform: translateY(0);
    }
    .layout-simple {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 1rem;
    }
    .layout-with-toc {
        display: flex;
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
        gap: 3rem;
    }

    .toc-sidebar {
        position: sticky;
        top: 64px;
        align-self: flex-start;
        width: 200px;
        flex-shrink: 0;
        padding: 2rem 0;
        max-height: calc(100vh - 64px);
        overflow-y: auto;
        scrollbar-width: none;
    }
    .toc-sidebar::-webkit-scrollbar {
        display: none;
    }

    .toc-label {
        font-size: 11px;
        color: var(--fg-dim);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.75rem;
        margin-top: 0;
    }
    .toc ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .toc li.depth-3 {
        padding-left: 0.75rem;
    }
    .toc a {
        display: block;
        font-size: 12px;
        color: var(--fg-dim);
        padding: 0.2rem 0.5rem;
        text-decoration: none;
        border-left: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
    }
    .toc a:hover {
        color: var(--fg);
        opacity: 1;
    }
    .toc a.active {
        color: var(--accent);
        border-left-color: var(--accent);
        opacity: 1;
    }

    main {
        flex: 1;
        min-width: 0;
        padding: 3rem 0;
        max-width: 720px;
    }
    .post-header {
        margin-bottom: 2rem;
    }
    .meta {
        font-size: 12px;
        color: var(--fg-dim);
        margin-bottom: 0.75rem;
    }
    .updated {
        font-style: italic;
    }
    .authors {
        color: var(--fg-muted);
    }
    .post-header h1 {
        font-size: 1.6rem;
        margin-bottom: 0.75rem;
    }
    .tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }
    .hero-img {
        margin-bottom: 2rem;
    }
    .hero-img img {
        width: 100%;
        border-radius: var(--radius);
    }
    .content {
        line-height: 1.8;
        overflow-wrap: break-word;
        word-wrap: break-word;
        word-break: break-word;
        min-width: 0;
    }
    .content :global(h2),
    .content :global(h3),
    .content :global(h4) {
        scroll-margin-top: 70px;
    }
    .content :global(h2) {
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--border);
    }
    .content :global(h3) {
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
    }
    .content :global(p) {
        margin-bottom: 1.25em;
    }
    .content :global(img) {
        margin: 1.5em 0;
        max-width: 100%;
        height: auto;
    }
    .content :global(pre) {
        margin: 1.5em 0;
        overflow-x: auto;
        max-width: 100%;
    }
    .content :global(code) {
        word-break: break-all;
    }
    .content :global(pre code) {
        word-break: normal;
    }

    .toc-fab {
        display: none;
    }

    .toc-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        backdrop-filter: blur(2px);
        z-index: 299;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease;
    }
    .toc-backdrop.open {
        opacity: 1;
        pointer-events: auto;
    }

    .toc-drawer {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        max-width: 360px;
        margin-left: auto;
        margin-right: auto;
        background: var(--bg-raised, #fff);
        border-top: 1px solid var(--border);
        border-radius: 16px 16px 0 0;
        padding: 0 1.25rem 2rem;
        z-index: 300;
        transform: translateY(100%);
        pointer-events: none;
        transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
        max-height: 65vh;
        overflow-y: auto;
        box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.12);
    }
    .toc-drawer::before {
        content: "";
        display: block;
        width: 36px;
        height: 4px;
        border-radius: 2px;
        background: var(--border);
        margin: 10px auto 4px;
    }
    .toc-drawer.open {
        transform: translateY(0);
        pointer-events: auto;
    }
    .toc-drawer-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem 0 0.25rem;
        margin-bottom: 0.25rem;
    }
    .toc-drawer-header .toc-label {
        margin: 0;
    }
    .toc-close {
        background: none;
        border: none;
        color: var(--fg-muted);
        font-size: 14px;
        cursor: pointer;
        padding: 4px 6px;
        border-radius: 4px;
        line-height: 1;
        transition: color 0.15s, background 0.15s;
    }
    .toc-close:hover {
        color: var(--fg);
        background: var(--bg-hover, rgba(0, 0, 0, 0.06));
    }
    .toc-mobile a {
        font-size: 13px;
        padding: 0.35rem 0.5rem;
    }

    @media (max-width: 768px) {
        .toc-sidebar {
            display: none;
        }
        .layout-with-toc {
            display: block;
            padding: 0 1rem;
        }
        .layout-simple {
            padding: 0 1rem;
        }
        main {
            padding: 1.5rem 0 5rem;
            max-width: 100%;
            overflow-x: hidden;
        }
        .post-header h1 {
            font-size: 1.3rem;
        }

        .toc-backdrop,
        .toc-drawer {
            display: block;
        }

        .toc-fab {
            display: flex;
            align-items: center;
            gap: 6px;
            position: fixed;
            bottom: 1.25rem;
            left: 1.25rem;
            z-index: 150;
            background: var(--bg-raised, #fff);
            border: 1px solid var(--border);
            color: var(--fg-muted);
            border-radius: 999px;
            padding: 0 14px 0 10px;
            height: 40px;
            font-size: 12px;
            font-family: var(--font);
            cursor: pointer;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
            transition: color 0.15s, border-color 0.15s, box-shadow 0.15s, transform 0.15s;
        }
        .toc-fab:hover,
        .toc-fab[aria-expanded="true"] {
            color: var(--accent);
            border-color: var(--accent);
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.14);
        }
        .toc-fab:active {
            transform: scale(0.96);
        }
        .toc-fab-label {
            line-height: 1;
        }

        .back-to-top {
            bottom: 1.25rem;
            right: 1.25rem;
        }
    }
</style>