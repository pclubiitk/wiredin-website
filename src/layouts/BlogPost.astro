---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

interface Heading {
    depth: number;
    slug: string;
    text: string;
}

type Props = CollectionEntry<"blog">["data"] & {
    headings?: Heading[];
};

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    tags,
    authors,
    enableToc,
    headings = [],
} = Astro.props;
const tocHeadings = headings.filter((h: Heading) => h.depth <= 3);
const showToc = enableToc && tocHeadings.length > 0;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
    </head>

    <body>
        <Header />

        <!-- Reading progress bar -->
        <div class="progress-bar" id="progress-bar"></div>

        <div class={showToc ? "layout-with-toc" : "layout-simple"}>
            {
                showToc && (
                    <aside class="toc-sidebar" id="toc-sidebar">
                        <nav class="toc">
                            <p class="toc-label">on this page</p>
                            <ul>
                                {tocHeadings.map((h) => (
                                    <li class={`depth-${h.depth}`}>
                                        <a href={`#${h.slug}`}>{h.text}</a>
                                    </li>
                                ))}
                            </ul>
                        </nav>
                    </aside>
                )
            }

            <main>
                <article>
                    <header class="post-header">
                        <p class="meta">
                            <FormattedDate date={pubDate} />
                            {
                                updatedDate && (
                                    <span class="updated">
                                        {" "}
                                        · updated{" "}
                                        <FormattedDate date={updatedDate} />
                                    </span>
                                )
                            }
                            {
                                authors && authors.length > 0 && (
                                    <span class="authors">
                                        {" "}
                                        · by {authors.join(", ")}
                                    </span>
                                )
                            }
                        </p>
                        <h1>{title}</h1>
                        {
                            tags && tags.length > 0 && (
                                <div class="tags">
                                    {tags.map((tag) => (
                                        <a href={`/tags/${tag}`} class="tag">
                                            #{tag}
                                        </a>
                                    ))}
                                </div>
                            )
                        }
                    </header>

                    {
                        heroImage && (
                            <div class="hero-img">
                                <Image
                                    width={1020}
                                    height={510}
                                    src={heroImage}
                                    alt=""
                                />
                            </div>
                        )
                    }

                    <div class="content">
                        <slot />
                    </div>
                </article>
            </main>
        </div>

        <!-- Back to top -->
        <button class="back-to-top" id="back-to-top" aria-label="Back to top"
            >↑</button
        >

        <Footer />

        <script>
            // Progress bar
            const bar = document.getElementById("progress-bar");
            function updateProgress() {
                const scrollTop = window.scrollY;
                const docHeight =
                    document.documentElement.scrollHeight - window.innerHeight;
                const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
                if (bar) bar.style.width = pct + "%";
            }
            window.addEventListener("scroll", updateProgress, {
                passive: true,
            });
            updateProgress();

            // Back to top
            const btn = document.getElementById("back-to-top");
            window.addEventListener(
                "scroll",
                () => {
                    if (btn)
                        btn.classList.toggle("visible", window.scrollY > 400);
                },
                { passive: true }
            );
            btn?.addEventListener("click", () =>
                window.scrollTo({ top: 0, behavior: "smooth" })
            );

            // ToC scroll spy
            const tocLinks = document.querySelectorAll(".toc a");
            if (tocLinks.length) {
                const headingEls = Array.from(tocLinks)
                    .map((link) => {
                        const id = link.getAttribute("href")?.slice(1);
                        return id ? document.getElementById(id) : null;
                    })
                    .filter(Boolean) as HTMLElement[];

                function updateToc() {
                    let current = 0;
                    for (let i = 0; i < headingEls.length; i++) {
                        if (headingEls[i].getBoundingClientRect().top <= 100)
                            current = i;
                    }
                    tocLinks.forEach((l, i) =>
                        l.classList.toggle("active", i === current)
                    );
                }
                window.addEventListener("scroll", updateToc, { passive: true });
                updateToc();
            }
        </script>
    </body>
</html>

<style>
    /* Progress bar */
    .progress-bar {
        position: fixed;
        top: 48px;
        left: 0;
        height: 2px;
        width: 0;
        background: var(--accent);
        z-index: 99;
        transition: width 0.05s linear;
    }

    /* Back to top */
    .back-to-top {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 36px;
        height: 36px;
        background: var(--bg-raised);
        border: 1px solid var(--border);
        color: var(--fg-muted);
        font-size: 16px;
        border-radius: var(--radius);
        cursor: pointer;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s, color 0.15s, border-color 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font);
    }
    .back-to-top.visible {
        opacity: 1;
        pointer-events: auto;
    }
    .back-to-top:hover {
        color: var(--accent);
        border-color: var(--accent);
    }

    /* Layouts */
    .layout-simple {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 1rem;
    }
    .layout-with-toc {
        display: flex;
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1rem;
        gap: 3rem;
    }

    /* ToC Sidebar */
    .toc-sidebar {
        position: sticky;
        top: 64px;
        align-self: flex-start;
        width: 200px;
        flex-shrink: 0;
        padding: 2rem 0;
        max-height: calc(100vh - 64px);
        overflow-y: auto;
        scrollbar-width: none;
    }
    .toc-sidebar::-webkit-scrollbar {
        display: none;
    }
    .toc-label {
        font-size: 11px;
        color: var(--fg-dim);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.75rem;
    }
    .toc ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .toc li.depth-3 {
        padding-left: 0.75rem;
    }
    .toc a {
        display: block;
        font-size: 12px;
        color: var(--fg-dim);
        padding: 0.2rem 0;
        text-decoration: none;
        border-left: 2px solid transparent;
        padding-left: 0.5rem;
        transition: color 0.15s, border-color 0.15s;
    }
    .toc a:hover {
        color: var(--fg);
        opacity: 1;
    }
    .toc a.active {
        color: var(--accent);
        border-left-color: var(--accent);
        opacity: 1;
    }

    /* Main content */
    main {
        flex: 1;
        min-width: 0;
        padding: 3rem 0;
        max-width: 720px;
    }
    .post-header {
        margin-bottom: 2rem;
    }
    .meta {
        font-size: 12px;
        color: var(--fg-dim);
        margin-bottom: 0.75rem;
    }
    .updated {
        font-style: italic;
    }
    .authors {
        color: var(--fg-muted);
    }
    .post-header h1 {
        font-size: 1.6rem;
        margin-bottom: 0.75rem;
    }
    .tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }
    .hero-img {
        margin-bottom: 2rem;
    }
    .hero-img img {
        width: 100%;
        border-radius: var(--radius);
    }

    .content {
        line-height: 1.8;
        overflow-wrap: break-word;
        word-wrap: break-word;
        word-break: break-word;
        min-width: 0;
    }
    .content :global(h2),
    .content :global(h3),
    .content :global(h4) {
        scroll-margin-top: 70px;
    }
    .content :global(h2) {
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--border);
    }
    .content :global(h3) {
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
    }
    .content :global(p) {
        margin-bottom: 1.25em;
    }
    .content :global(img) {
        margin: 1.5em 0;
        max-width: 100%;
        height: auto;
    }
    .content :global(pre) {
        margin: 1.5em 0;
        overflow-x: auto;
        max-width: 100%;
    }
    .content :global(code) {
        word-break: break-all;
    }
    .content :global(pre code) {
        word-break: normal;
    }

    @media (max-width: 768px) {
        .toc-sidebar {
            display: none;
        }
        .layout-with-toc {
            display: block;
            padding: 0 1rem;
        }
        .layout-simple {
            padding: 0 1rem;
        }
        main {
            padding: 1.5rem 0;
            max-width: 100%;
            overflow-x: hidden;
        }
        .post-header h1 {
            font-size: 1.3rem;
        }
    }
</style>
