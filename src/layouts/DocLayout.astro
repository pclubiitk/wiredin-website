---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Heading {
    depth: number;
    slug: string;
    text: string;
}

interface Props {
    title: string;
    description: string;
    headings: Heading[];
}

const { title, description, headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth <= 3);
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
    </head>
    <body>
        <Header />

        <div class="progress-bar" id="progress-bar"></div>

        <button class="back-to-top" id="back-to-top" aria-label="Back to top">
            ↑
        </button>

        <button class="toc-fab" id="toc-fab" aria-label="Table of contents" aria-expanded="false">
            <span class="toc-fab-icon">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="1" y="3" width="6" height="1.5" rx="0.75" fill="currentColor"/>
                    <rect x="1" y="7" width="9" height="1.5" rx="0.75" fill="currentColor"/>
                    <rect x="1" y="11" width="7" height="1.5" rx="0.75" fill="currentColor"/>
                    <rect x="9" y="3" width="6" height="1.5" rx="0.75" fill="currentColor" opacity="0.4"/>
                    <rect x="12" y="7" width="3" height="1.5" rx="0.75" fill="currentColor" opacity="0.4"/>
                    <rect x="10" y="11" width="5" height="1.5" rx="0.75" fill="currentColor" opacity="0.4"/>
                </svg>
            </span>
            <span class="toc-fab-label">Contents</span>
        </button>

        <div class="toc-backdrop" id="toc-backdrop"></div>

        <div class="toc-drawer" id="toc-drawer" role="dialog" aria-label="Table of contents" aria-modal="true">
            <div class="toc-drawer-header">
                <p class="toc-title">on this page</p>
                <button class="toc-close" id="toc-close" aria-label="Close table of contents">✕</button>
            </div>
            <nav class="toc toc-mobile">
                <ul>
                    {
                        tocHeadings.map((h) => (
                            <li class={`depth-${h.depth}`}>
                                <a href={`#${h.slug}`}>{h.text}</a>
                            </li>
                        ))
                    }
                </ul>
            </nav>
        </div>

        <div class="doc-layout">
            <aside class="sidebar" id="sidebar">
                <nav class="toc">
                    <p class="toc-title">on this page</p>
                    <ul>
                        {
                            tocHeadings.map((h) => (
                                <li class={`depth-${h.depth}`}>
                                    <a href={`#${h.slug}`}>{h.text}</a>
                                </li>
                            ))
                        }
                    </ul>
                </nav>
            </aside>
            <main>
                <header class="doc-header">
                    <h1>{title}</h1>
                    <p class="desc">{description}</p>
                </header>
                <div class="content">
                    <slot />
                </div>
            </main>
        </div>
        <Footer />

        <script>
            const progressBar = document.getElementById("progress-bar")!;
            function updateProgress() {
                const scrollTop = window.scrollY;
                const docHeight = document.documentElement.scrollHeight - window.innerHeight;
                const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
                progressBar.style.width = pct + "%";
            }

            const backToTop = document.getElementById("back-to-top")!;
            function updateBackToTop() {
                backToTop.classList.toggle("visible", window.scrollY > 300);
            }
            backToTop.addEventListener("click", () => {
                window.scrollTo({ top: 0, behavior: "smooth" });
            });

            // ── Desktop TOC active link ───────────────────────────────────
            const desktopLinks = document.querySelectorAll(".sidebar .toc a");
            const mobileLinks  = document.querySelectorAll(".toc-mobile a");
            const allTocLinks  = [...desktopLinks, ...mobileLinks];

            const headingEls = Array.from(desktopLinks)
                .map((link) => {
                    const id = link.getAttribute("href")?.slice(1);
                    return id ? document.getElementById(id) : null;
                })
                .filter(Boolean) as HTMLElement[];

            function updateActive() {
                let current = 0;
                for (let i = 0; i < headingEls.length; i++) {
                    if (headingEls[i].getBoundingClientRect().top <= 100) {
                        current = i;
                    }
                }
                desktopLinks.forEach((l, i) => l.classList.toggle("active", i === current));
                mobileLinks.forEach((l, i)  => l.classList.toggle("active", i === current));
            }

            window.addEventListener("scroll", () => {
                updateProgress();
                updateBackToTop();
                updateActive();
            }, { passive: true });

            // Run once on load
            updateProgress();
            updateBackToTop();
            updateActive();

            const fab      = document.getElementById("toc-fab")!;
            const drawer   = document.getElementById("toc-drawer")!;
            const backdrop = document.getElementById("toc-backdrop")!;
            const closeBtn = document.getElementById("toc-close")!;

            function openDrawer() {
                drawer.classList.add("open");
                backdrop.classList.add("open");
                fab.setAttribute("aria-expanded", "true");
                document.body.style.overflow = "hidden";
                // focus first link for a11y
                (drawer.querySelector("a") as HTMLElement)?.focus();
            }

            function closeDrawer() {
                drawer.classList.remove("open");
                backdrop.classList.remove("open");
                fab.setAttribute("aria-expanded", "false");
                document.body.style.overflow = "";
                fab.focus();
            }

            fab.addEventListener("click", openDrawer);
            closeBtn.addEventListener("click", closeDrawer);
            backdrop.addEventListener("click", closeDrawer);

            // Close on link click (navigate to section)
            mobileLinks.forEach((link) => {
                link.addEventListener("click", closeDrawer);
            });

            // Escape key
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape" && drawer.classList.contains("open")) closeDrawer();
            });
        </script>
    </body>
</html>

<style>
    .doc-layout {
        display: flex;
        max-width: 960px;
        margin: 0 auto;
        padding: 0 1rem;
        gap: 3rem;
    }

    .progress-bar {
        position: fixed;
        top: 48px;
        left: 0;
        height: 2px;
        width: 0;
        background: var(--accent);
        z-index: 200;
        transition: width 0.05s linear;
        pointer-events: none;
    }
    .back-to-top {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        width: 36px;
        height: 36px;
        background: var(--bg-raised);
        border: 1px solid var(--border);
        color: var(--fg-muted);
        font-size: 16px;
        border-radius: var(--radius);
        cursor: pointer;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s, color 0.15s, border-color 0.15s, transform 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font);
        z-index: 150;
    }
    .back-to-top.visible {
        opacity: 1;
        pointer-events: auto;
    }
    .back-to-top:hover {
        color: var(--accent);
        border-color: var(--accent);
        transform: translateY(-2px);
    }
    .back-to-top:active {
        transform: translateY(0);
    }

    .sidebar {
        position: sticky;
        top: 64px;
        align-self: flex-start;
        width: 200px;
        flex-shrink: 0;
        padding: 2rem 0;
        max-height: calc(100vh - 64px);
        overflow-y: auto;
        scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar {
        display: none;
    }

    .toc-title {
        font-size: 11px;
        color: var(--fg-dim);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.75rem;
        margin-top: 0;
    }
    .toc ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .toc li {
        margin-bottom: 0;
    }
    .toc li.depth-3 {
        padding-left: 0.75rem;
    }
    .toc a {
        display: block;
        font-size: 12px;
        color: var(--fg-dim);
        padding: 0.2rem 0;
        text-decoration: none;
        border-left: 2px solid transparent;
        padding-left: 0.5rem;
        transition: color 0.15s, border-color 0.15s;
    }
    .toc a:hover {
        color: var(--fg);
        opacity: 1;
    }
    .toc a.active {
        color: var(--accent);
        border-left-color: var(--accent);
        opacity: 1;
    }

    main {
        flex: 1;
        min-width: 0;
        padding: 2rem 0 3rem;
        max-width: 100%;
    }
    .doc-header {
        margin-bottom: 2rem;
    }
    .doc-header h1 {
        font-size: 1.6rem;
        margin-bottom: 0.5rem;
    }
    .desc {
        color: var(--fg-muted);
        font-size: 13px;
        margin: 0;
    }
    .content {
        line-height: 1.8;
    }
    .content :global(h2),
    .content :global(h3),
    .content :global(h4) {
        scroll-margin-top: 70px;
    }
    .content :global(h2) {
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--border);
    }
    .content :global(h3) {
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
    }
    .content :global(p) {
        margin-bottom: 1.25em;
    }
    .content :global(ul),
    .content :global(ol) {
        margin-bottom: 1.25em;
    }
    .content :global(pre) {
        margin: 1.5em 0;
    }

    .toc-fab {
        display: none;
    }

    .toc-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        backdrop-filter: blur(2px);
        z-index: 299;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease;
    }
    .toc-backdrop.open {
        pointer-events: auto;
    }

    .toc-drawer {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        /* cap width so it doesn't span full screen on wide phones in landscape */
        max-width: 360px;
        margin-left: auto;
        margin-right: auto;
        background: var(--bg-raised, #fff);
        border-top: 1px solid var(--border);
        border-radius: 16px 16px 0 0;
        padding: 0 1.25rem 2rem;
        z-index: 300;
        transform: translateY(100%);
        pointer-events: none;
        transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
        max-height: 65vh;
        overflow-y: auto;
        /* drag handle visual */
        box-shadow: 0 -4px 24px rgba(0,0,0,0.12);
    }
    .toc-drawer.open {
        pointer-events: auto;
    }
    .toc-drawer::before {
        content: "";
        display: block;
        width: 36px;
        height: 4px;
        border-radius: 2px;
        background: var(--border);
        margin: 10px auto 4px;
    }
    .toc-drawer-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem 0 0.25rem;
        margin-bottom: 0.25rem;
    }
    .toc-drawer-header .toc-title {
        margin: 0;
    }
    .toc-close {
        background: none;
        border: none;
        color: var(--fg-muted);
        font-size: 14px;
        cursor: pointer;
        padding: 4px 6px;
        border-radius: 4px;
        line-height: 1;
        transition: color 0.15s, background 0.15s;
    }
    .toc-close:hover {
        color: var(--fg);
        background: var(--bg-hover, rgba(0,0,0,0.06));
    }

    .toc-mobile a {
        font-size: 13px;
        padding: 0.35rem 0.5rem;
    }

    .toc-backdrop.open {
        opacity: 1;
        pointer-events: auto;
    }
    .toc-drawer.open {
        transform: translateY(0);
        pointer-events: auto;
    }

    @media (max-width: 768px) {
        .sidebar {
            display: none;
        }
        .doc-layout {
            display: block;
        }
        main {
            padding: 1.5rem 0 5rem; /* extra bottom so FAB doesn't cover content */
        }

        /* Show backdrop & drawer elements */
        .toc-backdrop,
        .toc-drawer {
            display: block;
        }

        /* FAB: thumb-friendly pill, bottom-left */
        .toc-fab {
            display: flex;
            align-items: center;
            gap: 6px;
            position: fixed;
            bottom: 1.25rem;
            left: 1.25rem;
            z-index: 150;
            background: var(--bg-raised, #fff);
            border: 1px solid var(--border);
            color: var(--fg-muted);
            border-radius: 999px;
            padding: 0 14px 0 10px;
            height: 40px;
            font-size: 12px;
            font-family: var(--font);
            cursor: pointer;
            box-shadow: 0 2px 12px rgba(0,0,0,0.1);
            transition: color 0.15s, border-color 0.15s, box-shadow 0.15s, transform 0.15s;
        }
        .toc-fab:hover,
        .toc-fab[aria-expanded="true"] {
            color: var(--accent);
            border-color: var(--accent);
            box-shadow: 0 4px 16px rgba(0,0,0,0.14);
        }
        .toc-fab:active {
            transform: scale(0.96);
        }
        .toc-fab-label {
            line-height: 1;
        }

        /* Back-to-top shifts left to not overlap FAB */
        .back-to-top {
            bottom: 1.25rem;
            right: 1.25rem;
        }
    }
</style>