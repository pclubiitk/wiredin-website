---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header>
	<nav>
		<a href="/" class="logo">
			{SITE_TITLE}<span class="blink">_</span>
		</a>

		<style>
			.blink {
				color: var(--accent);
				animation: blink 1s step-end infinite;
			}
			@keyframes blink {
				50% {
					opacity: 0;
				}
			}
		</style>
		<button class="toggle" aria-label="Menu" id="menu-toggle">
			<svg
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
			>
				<line x1="3" y1="6" x2="21" y2="6"></line>
				<line x1="3" y1="12" x2="21" y2="12"></line>
				<line x1="3" y1="18" x2="21" y2="18"></line>
			</svg>
		</button>
		<div class="links" id="nav-links">
			<HeaderLink href="/">home</HeaderLink>
			<HeaderLink href="/about">about</HeaderLink>
			<HeaderLink href="/members">members</HeaderLink>
			<HeaderLink href="/achievements">achievements</HeaderLink>
			<HeaderLink href="/blog">writeups</HeaderLink>
			<HeaderLink href="/resources">resources</HeaderLink>
		</div>
	</nav>
</header>

<script>
	document.getElementById("menu-toggle")?.addEventListener("click", () => {
		document.getElementById("nav-links")?.classList.toggle("open");
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1rem;
		height: 48px;
	}
	.logo {
		font-weight: 700;
		font-size: 15px;
		color: var(--fg);
		text-decoration: none;
		letter-spacing: -0.5px;
	}
	.logo:hover {
		opacity: 0.7;
	}
	.links {
		display: flex;
		gap: 0;
	}
	.links :global(a) {
		font-size: 13px;
		color: var(--fg-muted);
		padding: 0 0.6rem;
		text-decoration: none;
		transition: color 0.15s var(--ease);
	}
	.links :global(a:hover),
	.links :global(a.active) {
		color: var(--fg);
		opacity: 1;
	}
	.toggle {
		display: none;
		background: none;
		border: none;
		color: var(--fg-muted);
		cursor: pointer;
		padding: 4px;
	}

	@media (max-width: 600px) {
		.toggle {
			display: block;
		}
		.links {
			display: none;
			position: absolute;
			top: 48px;
			left: 0;
			right: 0;
			flex-direction: column;
			background: var(--bg);
			border-bottom: 1px solid var(--border);
			padding: 0.5rem 1rem 0.75rem;
		}
		.links.open {
			display: flex;
		}
		.links :global(a) {
			padding: 0.4rem 0;
			font-size: 14px;
		}
	}
</style>
